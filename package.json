{
  "name": "fabgrid",
  "version": "0.1.0",
  "private": true,
  "description": "Fabulous performance-first pure JavaScript data grid.",
  "type": "module",
  "main": "dist/fabui.js",
  "module": "dist/fabui.esm.js",
  "style": "dist/fabui.css",
  "scripts": {
    "build": "node build/build.cjs && node build/build-vue.cjs && node build/build-jquery.cjs && node build/build-vue-demo.cjs",
    "build:vue": "node build/build-vue.cjs",
    "build:vue-demo": "node build/build-vue-demo.cjs",
    "build:vue-prod": "vite build --config vite.config.js",
    "build:jquery": "node build/build-jquery.cjs",
    "dev:vue": "vite --config vite.config.js",
    "test": "node --test test/*.test.js",
    "test:jquery": "node --test test/jquery-wrapper.test.js",
    "smoke": "npm run build && node build/smoke.cjs",
    "serve": "python3 -m http.server 4173"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.3",
    "esbuild": "^0.28.1",
    "vite": "^5.4.21",
    "vue": "^2.7.16",
    "vue-template-compiler": "^2.7.16",
    "vue-template-es2015-compiler": "^1.9.1"
  }
}
